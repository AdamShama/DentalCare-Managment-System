<?xml version="1.0" encoding="UTF-8"?>
<jasperReport
  xmlns="http://jasperreports.sourceforge.net/jasperreports"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    http://jasperreports.sourceforge.net/jasperreports 
    http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
  name="PatientInvoice"
  pageWidth="595" pageHeight="842" columnWidth="555"
  leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

  <!-- PARAMETERS -->
  <parameter name="ClinicName"  class="java.lang.String"/>
  <parameter name="PatientName" class="java.lang.String"/>

  <!-- FIELDS -->
  <field name="ApptDate"      class="java.lang.String"/>
  <field name="TreatmentType" class="java.lang.String"/>
  <field name="Cost"          class="java.lang.Double"/>

  <!-- VARIABLE TO SUM COST -->
  <variable name="InvoiceTotal" class="java.lang.Double" calculation="Sum">
    <variableExpression><![CDATA[$F{Cost}]]></variableExpression>
    <initialValueExpression><![CDATA[0.0]]></initialValueExpression>
  </variable>

  <!-- TITLE BAND -->
  <title>
    <band height="70">
      <!-- Clinic Name -->
      <textField>
        <reportElement x="0" y="0" width="555" height="20"/>
        <textElement textAlignment="Center"><font size="12" isItalic="true"/></textElement>
        <textFieldExpression><![CDATA[$P{ClinicName}]]></textFieldExpression>
      </textField>

      <!-- Invoice for Patient -->
      <textField textAdjust="StretchHeight">
        <reportElement x="0" y="25" width="555" height="25"/>
        <textElement textAlignment="Center"><font size="16" isBold="true"/></textElement>
        <textFieldExpression><![CDATA[
          "Invoice for Patient " + $P{PatientName}
        ]]></textFieldExpression>
      </textField>
    </band>
  </title>

  <!-- COLUMN HEADERS -->
  <columnHeader>
    <band height="20">
      <staticText>
        <reportElement x="0" y="0" width="100" height="20"/>
        <textElement><font isBold="true"/></textElement>
        <text><![CDATA[Date]]></text>
      </staticText>
      <staticText>
        <reportElement x="100" y="0" width="300" height="20"/>
        <textElement><font isBold="true"/></textElement>
        <text><![CDATA[Treatment]]></text>
      </staticText>
      <staticText>
        <reportElement x="400" y="0" width="100" height="20"/>
        <textElement><font isBold="true"/></textElement>
        <text><![CDATA[Cost]]></text>
      </staticText>
    </band>
  </columnHeader>

  <!-- DETAIL ROW -->
  <detail>
    <band height="20">
      <textField>
        <reportElement x="0" y="0" width="100" height="20"/>
        <textFieldExpression><![CDATA[$F{ApptDate}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="100" y="0" width="300" height="20"/>
        <textFieldExpression><![CDATA[$F{TreatmentType}]]></textFieldExpression>
      </textField>
      <textField pattern="$ #,##0.00">
        <reportElement x="400" y="0" width="100" height="20"/>
        <textFieldExpression><![CDATA[$F{Cost}]]></textFieldExpression>
      </textField>
    </band>
  </detail>

  <!-- SUMMARY BAND -->
  <summary>
    <band height="30">
      <staticText>
        <reportElement x="300" y="5" width="100" height="20"/>
        <textElement><font isBold="true"/></textElement>
        <text><![CDATA[Total Due:]]></text>
      </staticText>
      <textField pattern="$ #,##0.00">
        <reportElement x="400" y="5" width="100" height="20"/>
        <textFieldExpression><![CDATA[$V{InvoiceTotal}]]></textFieldExpression>
      </textField>
    </band>
  </summary>
</jasperReport>
